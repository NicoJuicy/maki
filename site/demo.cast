[46.718153, "o", "\u001b[1;1H\u001b[39;48;2;34;36;48m  \u001b[38;2;98;114;164;48;2;34;36;48m  3 \u001b[38;2;248;248;242;48;2;34;36;48mMaki plugins are plain Lua files (Luau) that run inside maki. A plugin can\u001b[39;48;2;34;36;48m    \u001b[2;5H\u001b[38;2;98;114;164;48;2;34;36;48m4\u001b[2;7H\u001b[38;2;248;248;242;48;2;34;36;48mregister tools the LLM calls, slash commands, keymaps, prompt hints, and\u001b[3;5H\u001b[38;2;98;114;164;48;2;34;36;48m5\u001b[3;7H\u001b[38;2;248;248;242;48;2;34;36;48mcustom UI. Everything lives under the global `maki` table. An index of the\u001b[4;5H\u001b[38;2;98;114;164;48;2;34;36;48m6\u001b[4;7H\u001b[38;2;248;248;242;48;2;34;36;48mfull\u001b[4;12HAPI reference is at the end\u001b[4;40Hof this docume\u001b[4;55Ht.\u001b[39;48;2;34;36;48m                        \u001b[5;5H\u001b[38;2;98;114;164;48;2;34;36;48m7\u001b[5;7H\u001b[39;48;2;34;36;48m                                                                        \u001b[6;5H\u001b[38;2;98;114;164;48;2;34;36;48m8\u001b[6;7H\u001b[38;2;248;248;242;48;2;34;36;48m##\u001b[1m\u001b[38;2;189;147;249;48;2;34;36;48m Where plugin code goes\u001b[22m\u001b[39;48;2;34;36;48m                                                 \u001b[7;5H\u001b[38;2;98;114;164;48;2;34;36;48m9\u001b[7;7H\u001b[39;48;2;34;36;48m                                                  \u001b[8;4H\u001b[38;2;98;114;164;48;2;34;36;48m10\u001b[8;7H\u001b[38;2;248;248;242;48;2;34;36;48m-\u001b[38;2;139;233;253;48;2;34;36;48m \u001b[38;2;248;248;242;48;2;34;36;48m`~/.config/maki/init.lua`\u001b[38;2;139;233;253;48;2;34;36;48m - global, loaded for every project\u001b[9;4H\u001b[38;2;98;114;164;48;2;34;36;48m11\u001b[9;7H\u001b[38;2;248;248;242;48;2;34;36;48m-\u001b[38;2;139;233;253;48;2;34;36;48m \u001b[38;2;248;248;242;48;2;34;36;48m`<project>/.maki/init.lua`\u001b[38;2;139;233;253;48;2;34;36;48m - project-local\u001b[10;4H\u001b[38;2;98;114;164;48;2;34;36;48m12\u001b[11;5H3\u001b[11;7H\u001b[38;2;248;248;242;48;2;34;36;48mEither file can call `maki.setup({ ... })` for configuration and register\u001b[12;5H\u001b[38;2;98;114;164;48;2;34;36;48m4\u001b[12;7H\u001b[38;2;248;248;242;48;2;34;36;48mtools \u001b[12;14Hr \u001b[12;17Hommands. There are no separate plugin directories yet.\u001b[13;5H\u001b[38;2;98;114;164;48;2;34;36;48m5\u001b[14;5H6\u001b[14;7H\u001b[38;2;248;248;242;48;2;34;36;48m##\u001b[1m\u001b[38;2;189;147;249;48;2;"]
[46.718398, "o", "34;36;48m Development loop\u001b[22m\u001b[39;48;2;34;36;48m                                                      \u001b[15;5H\u001b[38;2;98;114;164;48;2;34;36;48m7\u001b[15;7H\u001b[39;48;2;34;36;48m                                                                \u001b[16;5H\u001b[38;2;98;114;164;48;2;34;36;48m8\u001b[16;7H\u001b[38;2;248;248;242;48;2;34;36;48mYou cannot run slash commands or restart maki. After editing, ask the user\u001b[17;5H\u001b[38;2;98;114;164;48;2;34;36;48m9\u001b[17;7H\u001b[38;2;248;248;242;48;2;34;36;48mto run `/reload` (rebuilds plugins and config in place). Until then your\u001b[18;4H\u001b[38;2;98;114;164;48;2;34;36;48m20\u001b[18;7H\u001b[38;2;248;248;242;48;2;34;36;48mchanges are not live. If a backtrace comes out useless, suggest restarting\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
