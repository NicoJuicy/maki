[119.109476, "o", "\u001b[1;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mUses \u001b[38;2;138;173;244;48;2;36;39;58mmaki.ui.open_win\u001b[38;2;202;211;245;48;2;36;39;58m + a \u001b[38;2;138;173;244;48;2;36;39;58mwin:recv(tick_interval)\u001b[38;2;202;211;245;48;2;36;39;58m loop; the \u001b[38;2;138;173;244;48;2;36;39;58mtimeout\u001b[38;2;202;211;245;48;2;36;39;58m event doubles\u001b[39;48;2;36;39;58m   \u001b[2;1H\u001b[38;2;202;211;245;48;2;36;39;58mas the game tick, key events steer/pause/restart.\u001b[39;48;2;36;39;58m                                     \u001b[3;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mRenders each frame by building a 2D grid, grouping runs of same-colored cells into\u001b[39;48;2;36;39;58m  \u001b[4;1H\u001b[38;2;202;211;245;48;2;36;39;58mstyled \u001b[38;2;138;173;244;48;2;36;39;58mbuf:set_lines\u001b[38;2;202;211;245;48;2;36;39;58m spans (two spaces per cell for ~square aspect).\u001b[39;48;2;36;39;58m                  \u001b[5;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mReversal-safe direction queue (can't insta-turn into your own neck),\u001b[39;48;2;36;39;58m                \u001b[6;1H\u001b[38;2;202;211;245;48;2;36;39;58mtail-vacates-cell rule for self-collision, and a board-full → \"YOU WIN\" guard.\u001b[39;48;2;36;39;58m        \u001b[7;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mSyntax-verified with \u001b[38;2;138;173;244;48;2;36;39;58mluajit -e loadfile\u001b[38;2;202;211;245;48;2;36;39;58m.\u001b[39;48;2;36;39;58m                                            \u001b[8;1H                                                                                      \u001b[9;1H\u001b[38;2;202;211;245;48;2;36;39;58mTwo things to flag honestly:\u001b[39;48;2;36;39;58m                                                          \u001b[10;1H                                                                                      \u001b[11;1H\u001b[38;2;145;215;227;48;2;36;39;58m1. \u001b[38;2;202;211;245;48;2;36;39;58mI couldn't run \u001b[38;2;138;173;244;48;2;36;39;58m/reload\u001b[38;2;202;211;245;48;2;36;39;58m or \u001b[38;2;138;173;244;48;2;36;39;58m/snake\u001b[38;2;202;211;245;48;2;36;39;58"]
[119.109841, "o", "m myself — that's on you. If an arrow key does\u001b[39;48;2;36;39;58m      \u001b[12;1H\u001b[38;2;202;211;245;48;2;36;39;58mnothing, \u001b[38;2;138;173;244;48;2;36;39;58mmaki.log.info\u001b[38;2;202;211;245;48;2;36;39;58m will log the unhandled key name (in \u001b[38;2;138;173;244;48;2;36;39;58m~/.local/logs/maki/\u001b[38;2;202;211;245;48;2;36;39;58m);\u001b[39;48;2;36;39;58m      \u001b[13;1H\u001b[38;2;138;173;244;48;2;36;39;58mhjkl\u001b[38;2;202;211;245;48;2;36;39;58m/\u001b[38;2;138;173;244;48;2;36;39;58mwasd\u001b[38;2;202;211;245;48;2;36;39;58m are a safe fallback regardless.\u001b[39;48;2;36;39;58m                                             \u001b[14;1H\u001b[38;2;145;215;227;48;2;36;39;58m2. \u001b[38;2;202;211;245;48;2;36;39;58mTiming uses \u001b[38;2;138;173;244;48;2;36;39;58mrecv\u001b[38;2;202;211;245;48;2;36;39;58m timeouts rather than a wall clock (\u001b[38;2;138;173;244;48;2;36;39;58mmaki.uv\u001b[38;2;202;211;245;48;2;36;39;58m exposes no high-res\u001b[39;48;2;36;39;58m    \u001b[15;1H\u001b[38;2;202;211;245;48;2;36;39;58mtimer), so mashing keys quickly can briefly slow the tick — fine for normal play,\u001b[39;48;2;36;39;58m     \u001b[16;1H\u001b[38;2;202;211;245;48;2;36;39;58mjust not frame-perfect.\u001b[39;48;2;36;39;58m                                                               \u001b[17;1H                                                                                     ▐\u001b[18;1H\u001b[38;2;202;211;245;48;2;36;39;58mRun \u001b[38;2;138;173;244;48;2;36;39;58m/reload\u001b[38;2;202;211;245;48;2;36;39;58m, then \u001b[38;2;138;173;244;48;2;36;39;58m/snake\u001b[38;2;202;211;245;48;2;36;39;58m and enjoy.\u001b[39;48;2;36;39;58m                                                  ▐\u001b[19;1H\u001b[38;2;145;215;227;48;2;36;39;58m──────────────────────────────────────────────────────────────────────────────────────\u001b[20;1H\u001b[38;2;110;115;141;48;2;36;39;58m❯ \u001b[7mA\u001b[27msk maki to \u001b[3mfix a bug\u001b[23m...\u001b[38;2;202;211;245;48;2;36;39;58m                                                            "]
