[120.65001, "o", "\u001b[1;1H\u001b[38;2;36;39;58;48;2;198;160;246m /tasks     Browse and search tasks \u001b[39;48;2;36;39;58m                                          \u001b[2;1H \u001b[38;2;183;189;248;48;2;36;39;58m/compact\u001b[39;48;2;36;39;58m   \u001b[38;2;110;115;141;48;2;36;39;58mSummarize and compact conversation history\u001b[3;1H\u001b[39;48;2;36;39;58m \u001b[38;2;183;189;248;48;2;36;39;58m/new\u001b[39;48;2;36;39;58m       \u001b[38;2;110;115;141;48;2;36;39;58mStart a new session\u001b[39;48;2;36;39;58m                                               \u001b[4;1H \u001b[38;2;183;189;248;48;2;36;39;58m/help\u001b[39;48;2;36;39;58m      \u001b[38;2;110;115;141;48;2;36;39;58mShow keybindings\u001b[39;48;2;36;39;58m                                        \u001b[5;1H \u001b[38;2;183;189;248;48;2;36;39;58m/usage\u001b[39;48;2;36;39;58m     \u001b[38;2;110;115;141;48;2;36;39;58mShow token usage breakdown\u001b[39;48;2;36;39;58m                                \u001b[6;1H \u001b[38;2;183;189;248;48;2;36;39;58m/queue\u001b[39;48;2;36;39;58m     \u001b[38;2;110;115;141;48;2;36;39;58mRemove items from queue\u001b[39;48;2;36;39;58m                                           \u001b[7;1H \u001b[38;2;183;189;248;48;2;36;39;58m/model\u001b[39;48;2;36;39;58m     \u001b[38;2;110;115;141;48;2;36;39;58mSwitch model\u001b[39;48;2;36;39;58m                  \u001b[8;2H\u001b[38;2;183;189;248;48;2;36;39;58m/theme\u001b[8;13H\u001b[38;2;110;115;141;48;2;36;39;58mSwitch color theme\u001b[9;1H\u001b[39;48;2;36;39;58m \u001b[38;2;183;189;248;48;2;36;39;58m/mcp\u001b[39;48;2;36;39;58m       \u001b[38;2;110;115;141;48;2;36;39;58mConfigure MCP servers\u001b[10;2H\u001b[38;2;183;189;248;48;2;36;39;58m/login\u001b[10;13H\u001b[38;2;110;115;141;48;2;36;39;58mAuthenticate with an LLM provider\u001b[11;1H\u001b[39;48;2;36;39;58m \u001b[38;2;183;189;248;48;2;36;39;58m/cd\u001b[39;48;2;36;39;58m        \u001b[38;2;110;115;141;48;2;36;39;58mChange working directory\u001b[39;48;2;36;39;58m                                          \u001b[12;1H \u001b[38;2;183;189;248;48;2;36;39;58m/btw\u001b[39;48;2;36;39;58m       \u001b[38;2;110;115;141;48;2;36;39;58mAsk a quick question (no tools, no history pollution)\u001b[39;48;2;36;39;58m             \u001b[13;1H \u001b[38;2;183;189;248;48;2;36;39;58m/yolo\u001b[39;48;2;36;39;58m      \u001b[38;2;110;115;141;48;2;36;"]
[120.65014, "o", "39;58mToggle YOLO mode (skip all permission prompts)\u001b[14;1H\u001b[39;48;2;36;39;58m \u001b[38;2;183;189;248;48;2;36;39;58m/thinking\u001b[39;48;2;36;39;58m  \u001b[38;2;110;115;141;48;2;36;39;58mToggle extended thinking (off, adaptive, effort level, or budget)\u001b[39;48;2;36;39;58m \u001b[15;1H \u001b[38;2;183;189;248;48;2;36;39;58m/fast\u001b[39;48;2;36;39;58m      \u001b[38;2;110;115;141;48;2;36;39;58mToggle Anthropic fast mode (Opus only)\u001b[39;48;2;36;39;58m                            \u001b[16;1H \u001b[38;2;183;189;248;48;2;36;39;58m/workflow\u001b[39;48;2;36;39;58m  \u001b[38;2;110;115;141;48;2;36;39;58mToggle workflow mode (task callable inside code_execution)\u001b[17;2H\u001b[38;2;183;189;248;48;2;36;39;58m/exit\u001b[17;13H\u001b[38;2;110;115;141;48;2;36;39;58mExit the application\u001b[18;1H\u001b[39;48;2;36;39;58m \u001b[38;2;183;189;248;48;2;36;39;58m/reload\u001b[39;48;2;36;39;58m    \u001b[38;2;110;115;141;48;2;36;39;58mReload plugins and config\u001b[20;3H\u001b[38;2;202;211;245;48;2;36;39;58m/\u001b[7m \u001b[27m                      \u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
