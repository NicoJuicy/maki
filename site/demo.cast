[112.441231, "o", "58m.\u001b[8;1H\u001b[39;48;2;36;39;58m                                                                              \u001b[9;1H\u001b[38;2;202;211;245;48;2;36;39;58mTwo things\u001b[9;13Ho flag honestly:\u001b[39;48;2;36;39;58m                 \u001b[11;1H\u001b[38;2;145;215;227;48;2;36;39;58m1. \u001b[38;2;202;211;245;48;2;36;39;58mI couldn't run \u001b[38;2;138;173;244;48;2;36;39;58m/reload\u001b[38;2;202;211;245;48;2;36;39;58m or \u001b[38;2;138;173;244;48;2;36;39;58m/snake\u001b[38;2;202;211;245;48;2;36;39;58m myself — that's on you. If an arrow key does\u001b[12;1Hnothing, \u001b[38;2;138;173;244;48;2;36;39;58mmaki.log.info\u001b[38;2;202;211;245;48;2;36;39;58m will log the unhandled key name (in \u001b[38;2;138;173;244;48;2;36;39;58m~/.local/logs/maki/\u001b[38;2;202;211;245;48;2;36;39;58m);\u001b[13;1H\u001b[38;2;138;173;244;48;2;36;39;58mhjkl\u001b[38;2;202;211;245;48;2;36;39;58m/\u001b[38;2;138;173;244;48;2;36;39;58mwasd\u001b[38;2;202;211;245;48;2;36;39;58m are a safe fallb\u001b[13;28Hck regardless.\u001b[39;48;2;36;39;58m                                          \u001b[14;1H\u001b[38;2;145;215;227;48;2;36;39;58m2. \u001b[38;2;202;211;245;48;2;36;39;58mTiming uses \u001b[38;2;138;173;244;48;2;36;39;58mrecv\u001b[38;2;202;211;245;48;2;36;39;58m timeou\u001b[14;30Hrather than a wall clock (\u001b[38;2;138;173;244;48;2;36;39;58mmaki.uv\u001b[38;2;202;211;245;48;2;36;39;58m exposes no high-res\u001b[15;1Htim\u001b[15;5Hr), \u001b[15;10Ho mashing keys\u001b[15;25Hq\u001b[15;28Hckly c\u001b[15;35Hn briefly\u001b[15;45Hsl\u001b[15;48Hw the\u001b[15;54Htick\u001b[15;59H— fine for normal p\u001b[15;79Hay,\u001b[39;48;2;36;39;58m   \u001b[16;1H\u001b[38;2;202;211;245;48;2;36;39;58mjust not frame-perfect.\u001b[39;48;2;36;39;58m                                             \u001b[17;1H                                                                      \u001b[18;1H\u001b[38;2;202;211;245;48;2;36;39;58mRun \u001b[38;2;138;173;244;48;2;36;39;58m/re