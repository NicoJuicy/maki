[43.863814, "o", "164;48;2;34;36;48m  3 \u001b[38;2;248;248;242;48;2;34;36;48mMaki plugins are plain Lua files (Luau) that run inside maki. A plugin can\u001b[39;48;2;34;36;48m    \u001b[8;5H\u001b[38;2;98;114;164;48;2;34;36;48m4\u001b[8;7H\u001b[38;2;248;248;242;48;2;34;36;48mregister tools the LLM calls, slash commands, keymaps, prompt hints, and\u001b[9;5H\u001b[38;2;98;114;164;48;2;34;36;48m5\u001b[9;7H\u001b[38;2;248;248;242;48;2;34;36;48mcustom UI. Everything lives under the global `maki` table. An index of the\u001b[10;5H\u001b[38;2;98;114;164;48;2;34;36;48m6\u001b[10;7H\u001b[38;2;248;248;242;48;2;34;36;48mfull\u001b[10;12HAPI reference is at the end\u001b[10;40Hof this docume\u001b[10;55Ht.\u001b[39;48;2;34;36;48m                        \u001b[11;5H\u001b[38;2;98;114;164;48;2;34;36;48m7\u001b[11;7H\u001b[39;48;2;34;36;48m                                                                        \u001b[12;5H\u001b[38;2;98;114;164;48;2;34;36;48m8\u001b[12;7H\u001b[38;2;248;248;242;48;2;34;36;48m##\u001b[1m\u001b[38;2;189;147;249;48;2;34;36;48m Where plugin code goes\u001b[22m\u001b[39;48;2;34;36;48m                                                 \u001b[13;5H\u001b[38;2;98;114;"]
[43.863894, "o", "164;48;2;34;36;48m9\u001b[13;7H\u001b[39;48;2;34;36;48m                                                  \u001b[14;4H\u001b[38;2;98;114;164;48;2;34;36;48m10\u001b[14;7H\u001b[38;2;248;248;242;48;2;34;36;48m-\u001b[38;2;139;233;253;48;2;34;36;48m \u001b[38;2;248;248;242;48;2;34;36;48m`~/.config/maki/init.lua`\u001b[38;2;139;233;253;48;2;34;36;48m - global, loaded for every project\u001b[15;4H\u001b[38;2;98;114;164;48;2;34;36;48m11\u001b[15;7H\u001b[38;2;248;248;242;48;2;34;36;48m-\u001b[38;2;139;233;253;48;2;34;36;48m \u001b[38;2;248;248;242;48;2;34;36;48m`<project>/.maki/init.lua`\u001b[38;2;139;233;253;48;2;34;36;48m - project-local\u001b[16;4H\u001b[38;2;98;114;164;48;2;34;36;48m12\u001b[17;5H3\u001b[17;7H\u001b[38;2;248;248;242;48;2;34;36;48mEither file can call `maki.setup({ ... })` for configuration and register\u001b[18;5H\u001b[38;2;98;114;164;48;2;34;36;48m4\u001b[18;7H\u001b[38;2;248;248;242;48;2;34;36;48mtools \u001b[18;14Hr \u001b[18;17Hommands. There are no separate plugin directories yet.\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
