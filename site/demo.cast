6;48m7\u001b[12;7H\u001b[39;48;2;34;36;48m                                                                \u001b[13;5H\u001b[38;2;98;114;164;48;2;34;36;48m8\u001b[13;7H\u001b[38;2;248;248;242;48;2;34;36;48mYou cannot run slash commands or restart maki. After editing, ask the user\u001b[14;5H\u001b[38;2;98;114;164;48;2;34;36;48m9\u001b[14;7H\u001b[38;2;248;248;242;48;2;34;36;48mto run `/reload` (rebuilds plugins "]
[47.708064, "o", "and config in place). Until then your\u001b[15;4H\u001b[38;2;98;114;164;48;2;34;36;48m20\u001b[15;7H\u001b[38;2;248;248;242;48;2;34;36;48mchanges are not live. If a backtrace comes out useless, suggest restarting\u001b[16;4H\u001b[38;2;98;114;164;48;2;34;36;48m21\u001b[16;7H\u001b[38;2;248;248;242;48;2;34;36;48mwith `--no-jit`.\u001b[39;48;2;34;36;48m                                                          \u001b[17;4H\u001b[38;2;98;114;164;48;2;34;36;48m22\u001b[17;7H\u001b[39;48;2;34;36;48m                                                                        \u001b[18;5H\u001b[38;2;98;114;164;48;2;34;36;48m3\u001b[18;7H\u001b[38;2;248;248;242;48;2;34;36;48mTo debug, add `maki.log.info|warn|error(...)` calls. They write\u001b[18;71Hto `mak\u001b[18;79H.log`\u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
