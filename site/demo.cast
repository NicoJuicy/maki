[114.524095, "o", "\u001b[1;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mUses \u001b[38;2;138;173;244;48;2;36;39;58mmaki.ui.open_win\u001b[38;2;202;211;245;48;2;36;39;58m + a \u001b[38;2;138;173;244;48;2;36;39;58mwin:recv(tick_interval)\u001b[38;2;202;211;245;48;2;36;39;58m loop; the \u001b[38;2;138;173;244;48;2;36;39;58mtimeout\u001b[38;2;202;211;245;48;2;36;39;58m event do\u001b[2;1Has the game tick, key events steer/pause/restart.\u001b[39;48;2;36;39;58m     \u001b[3;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mRenders each frame by building a 2D grid, grouping runs of same-colored cell\u001b[4;1Hstyled \u001b[38;2;138;173;244;48;2;36;39;58mbuf:set_lines\u001b[38;2;202;211;245;48;2;36;39;58m spans (two spaces per cell for ~square aspect).\u001b[5;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mReversal-safe direction queue (can't insta-turn into your own neck),\u001b[6;1Htail-vacates-cell rule for self-collision, and a board-full → \"YOU WIN\" guard.\u001b[7;1H\u001b[38;2;145;215;227;48;2;36;39;58m• \u001b[38;2;202;211;245;48;2;36;39;58mSyntax-verified with \u001b[38;2;138;173;244;48;2;36;39;58mluajit -e loadfile\u001b[38;2;202;211;245;48;2;36;39;58m.\u001b[8;2H\u001b[39;48;2;36;39;58m      \u001b[8;13H                  \u001b[9;1H\u001b[38;2;202;211;245;48;2;36;39;58mTwo things to flag honestly:\u001b[39;48;2;36;39;58m     \u001b[10;2H      \u001b[10;13H                                 \u001b[11;1H\u001b[38;2;145;215;227;48;2;36;39;58m1. \u001b[38;2;202;211;245;48;2;36;39;58mI couldn't run \u001b[38;2;138;173;244;48;2;36;39;58m/reload\u001b[38;2;202;211;245;48;2;36;39;58m or \u001b[38;2;138;173;244;48;2;36;39;58m/snake\u001b[38;2;202;211;245;48;2;36;39;58m myself — that's on you. If an arrow key do\u001b[12;1Hnothing, \u001b[38;2;138;173;244;48;2;36;39;58mmaki.log.info\u001b[38;2;202;211;245;48;2;36;39;58m will log the unhandled key name (in \u001b[38;2;138;173;244;48;2;36;39;58m~/.local/logs/maki/\u001b[13;1Hhjkl\u001b[38;2;202;211;245;48;2;36;39;58m/\u001b[38;2;138;173;244;48;2;36;39;58mwasd\u001b[38;2;202;211;245;48;2;36;39;58m are a safe fallback regardless.\u001b[39;48;2;36;39;58m                 \u001b[14;1H\u001b[38;2;145;215;227;48;2;36;39;58m2. \u001b[38;2;202;211;245;48;2;36;39;58mTiming uses \u001b[38;2;138;173;244;48;2;36;39;58mrecv\u001b[38;2;202;211;245;48;2;36;39;58m timeouts rather than a wall clock (\u001b[38;2;138;173;244;48;2;36;39;58mmaki.uv\u001b[38;2;202;211;245;48;2;36;39;58m exposes no high\u001b[15;1H\u001b[38;2;36;39;58;48;2;198;160;246m /\u001b[1m\u001b[39;48;2;198;160;246mr\u001b[22m\u001b[38;2;36;39;58;48;2;198;160;246meload    Reload plugins and config \u001b[39;48;2;36;39;58m            \u001b[15;72H\u001b[38;2;202;211;245;48;2;36;39;58mrmal pl\u001b[16;3H\u001b[1m\u001b[39;48;2;36;39;58mr\u001b[22m\u001b[38;2;183;189;248;48;2;36;39;58mename\u001b[39;48;2;36;39;58m  \u001b[16;13H\u001b[38;2;110;115;141;48;2;36;39;58mRenam\u001b[16;20Hthe current session\u001b[39;48;2;36;39;58m                                \u001b[17;3H\u001b[38;2;183;189;248;48;2;36;39;58mmemo\u001b[1m\u001b[39;48;2;36;39;58mr\u001b[22m\u001b[38;2;183;189;248;48;2;36;39;58my\u001b[17;13H\u001b[38;2;110;115;141;48;2;36;39;58mView, edit, and delete memory files\u001b[18;3H\u001b[38;2;183;189;248;48;2;36;39;58mwo\u001b[1m\u001b[39;48;2;36;39;58mr\u001b[22m\u001b[38;2;183;189;248;48;2;36;39;58mkflow\u001b[18;13H\u001b[38;2;110;115;141;48;2;36;39;58mToggle\u001b[18;20Hworkflow mode (task callable inside code_execution)\u001b[20;4H\u001b[38;2;202;211;245;48;2;36;39;58mr\u001b[7m \u001b[39m\u001b[49m\u001b[59m\u001b[0m\u001b[?25l"]
